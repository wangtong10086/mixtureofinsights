---
import { getCollection } from 'astro:content';
import { t, langOf, slugOf, postUrl, seriesKeys, seriesName, seriesBlurb, type Lang } from '../i18n';
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang);
const all = await getCollection('blog');
const mine = all.filter((p) => langOf(p.id) === lang);
const keys = seriesKeys(mine);
const groups = keys.map((k) => ({
  key: k,
  name: seriesName(k, lang),
  blurb: seriesBlurb(k, lang),
  posts: mine.filter((p) => p.data.series === k).sort((a, b) => a.data.order - b.data.order),
}));
const notes = mine.filter((p) => !p.data.series).sort((a, b) => +b.data.date - +a.data.date);
const locale = lang === 'zh' ? 'zh-CN' : 'en';
const fmt = (d) => new Intl.DateTimeFormat(locale, { year: 'numeric', month: 'short', day: 'numeric' }).format(d);
const cover = (p) => `/og/${slugOf(p.id)}.jpg`;
const href = (p) => postUrl(lang, slugOf(p.id));
---
<section class="wrap hero">
  <h1>{tr('hero.title')}</h1>
  <p>{tr('hero.desc')}</p>
</section>

<section class="wrap">
  {groups.map((g) => (
    <>
      <header class="section-head">
        <span class="kicker">{tr('section.series')}</span>
        <h2 class="section-title">{g.name}</h2>
        {g.blurb && <p class="section-sub">{g.blurb}</p>}
      </header>
      <ul class="posts">
        {g.posts.map((p) => (
          <li class="post-item">
            <a href={href(p)} class="post-link">
              <img class="thumb" src={cover(p)} alt="" width="160" height="160" loading="lazy" />
              <div class="post-body">
                <div class="meta">{fmt(p.data.date)}{p.data.reading ? ` · ${p.data.reading}` : ''}</div>
                <h2><span class="idx">{String(p.data.order).padStart(2, '0')}</span>{p.data.title}</h2>
                <p>{p.data.description}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </>
  ))}

  {notes.length > 0 && (
    <header class="section-head" style="margin-top:3.4rem">
      <span class="kicker">{tr('section.notes')}</span>
      <h2 class="section-title">{tr('section.notesSub')}</h2>
    </header>
  )}
  <ul class="posts">
    {notes.map((p) => (
      <li class="post-item">
        <a href={href(p)} class="post-link">
          <img class="thumb" src={cover(p)} alt="" width="160" height="160" loading="lazy" />
          <div class="post-body">
            <div class="meta">{fmt(p.data.date)}{p.data.reading ? ` · ${p.data.reading}` : ''}</div>
            <h2>{p.data.title}</h2>
            <p>{p.data.description}</p>
          </div>
        </a>
      </li>
    ))}
  </ul>
</section>
