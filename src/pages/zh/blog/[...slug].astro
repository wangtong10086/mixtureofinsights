---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Post from '../../../components/Post.astro';
import { langOf, slugOf } from '../../../i18n';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const mine = all.filter((p) => langOf(p.id) === 'zh');
  return mine.map((post) => {
    let prev = null, next = null;
    if (post.data.series) {
      const sib = mine.filter((p) => p.data.series === post.data.series).sort((a, b) => a.data.order - b.data.order);
      const i = sib.findIndex((p) => p.id === post.id);
      prev = sib[i - 1] ?? null; next = sib[i + 1] ?? null;
    }
    return { params: { slug: slugOf(post.id) }, props: { post, prev, next } };
  });
}
const { post, prev, next } = Astro.props;
---
<Base title={post.data.title} description={post.data.description} image={`/og/${slugOf(post.id)}.jpg`} type="article" date={post.data.date} lang="zh">
  <Post post={post} prev={prev} next={next} lang="zh" />
</Base>
