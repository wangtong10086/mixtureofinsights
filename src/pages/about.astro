---
import Base from '../layouts/Base.astro';
const LINKEDIN = 'https://www.linkedin.com/in/%E9%80%9A-%E7%8E%8B-190ba329a/';
const GITHUB = 'https://github.com/wangtong10086';
const EMAIL = 'wangtong91347625@gmail.com';
const gh = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .319.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`;
const li = `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>`;
const em = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 6 9-6"/></svg>`;
---
<Base title="About" description="Wang Tong — LLM post-training & agent algorithm engineer." lang="en">
  <article class="wrap article">
    <div class="profile-head">
      <div class="profile-avatar">王</div>
      <div>
        <h1 class="profile-name">Wang Tong · 王通</h1>
        <p class="profile-role">LLM post-training &amp; agent algorithm engineer — alignment, RL, reward modeling.</p>
      </div>
    </div>

    <div class="profile-links">
      <a href={GITHUB} target="_blank" rel="me noopener"><Fragment set:html={gh} />GitHub</a>
      <a href={LINKEDIN} target="_blank" rel="me noopener"><Fragment set:html={li} />LinkedIn</a>
      <a href={`mailto:${EMAIL}`}><Fragment set:html={em} />Email</a>
    </div>

    <div class="prose">
      <p>
        I'm an LLM algorithm engineer focused on <strong>post-training and alignment</strong> —
        SFT, DPO, RLHF / RLVR, PPO, GRPO and reward modeling — and on the data engines that feed
        them: synthetic data, self-play, rejection sampling and LLM-as-judge. I like owning the
        whole loop, from <em>data generation → training → offline/online evaluation → deployment</em>,
        and I care as much about the eval harness and the verifier as about the training run.
      </p>
      <p><strong>Lately.</strong> RL for reasoning &amp; planning agents (a GRPO + reward-model
        pipeline that lifted complex-constraint satisfaction ~12% on an internal planning
        benchmark); online distillation (a Qwen 35B→4B Forward-KL setup on 8×H200); evaluation
        harnesses for browser and software-engineering agents (LiveWeb, SWE trajectories); and the
        training/eval orchestration to run all of it on remote GPUs. Tooling I reach for: PyTorch,
        DeepSpeed / Megatron, vLLM / SGLang, ms-swift, and a lot of CUDA.
      </p>
      <p><strong>About this blog.</strong> The name is a small joke — a <em>mixture of experts</em>,
        rerouted toward whatever I'm currently nerd-sniped by. Most of my work is on language
        models; some of it is far below them. The writing here is the second kind: long-form
        field notes from days spent at a low layer, hitting a wall, and working out exactly where
        the wall is. The inaugural series reverse-engineers how a phone's apps detect a modified
        OS — a systems deep-dive that happens to show how I debug everything else.
      </p>
      <blockquote>
        <p>Prove the failure before you prescribe the fix; know which wall you're standing at
        before you spend a week pushing on it.</p>
      </blockquote>
      <p>
        Hiring for LLM post-training / agents, building something at this layer, or just want to
        compare notes? Reach me on
        <a href={GITHUB} target="_blank" rel="noopener">GitHub</a>,
        <a href={LINKEDIN} target="_blank" rel="noopener">LinkedIn</a>, or by
        <a href={`mailto:${EMAIL}`}>email</a>.
      </p>
    </div>
  </article>
</Base>
